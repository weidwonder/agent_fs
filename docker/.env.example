# docker/.env.example
# Copy this file to docker/.env and adjust values for your environment.
# Usage: cd docker && cp .env.example .env && docker compose up --build -d

# ─── PostgreSQL ───────────────────────────────────────────────
# Database name
POSTGRES_DB=agentfs
# Database user
POSTGRES_USER=agentfs
# Database password — CHANGE THIS in production
POSTGRES_PASSWORD=changeme
# Host port to expose PostgreSQL on (default: 5432)
PG_PORT=5432

# ─── MinIO / S3 ───────────────────────────────────────────────
# MinIO root user (used as S3 access key)
S3_ACCESS_KEY=minioadmin
# MinIO root password (used as S3 secret key) — CHANGE THIS in production
S3_SECRET_KEY=minioadmin
# S3 bucket name for file storage
S3_BUCKET=agentfs
# Host port to expose MinIO API on (default: 9000)
MINIO_PORT=9000
# Host port to expose MinIO web console on (default: 9001)
MINIO_CONSOLE_PORT=9001
# S3 endpoint as seen by the app (internal docker network address)
S3_ENDPOINT=http://minio:9000

# ─── Application ─────────────────────────────────────────────
# Host port to expose the server on (default: 3000)
APP_PORT=3000
# JWT signing secret — CHANGE THIS in production (use a long random string)
JWT_SECRET=change-me-in-production
# JWT access token expiry (e.g. 15m, 1h)
JWT_EXPIRES_IN=15m
# JWT refresh token expiry (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d
